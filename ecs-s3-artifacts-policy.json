{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListArtifactBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::rag-testgen-artifacts-989571800722-ap-south-1"
    },
    {
      "Sid": "ReadWriteArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::rag-testgen-artifacts-989571800722-ap-south-1/*"
    }
  ]
}
